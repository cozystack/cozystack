#!/bin/sh
# Fake kubectl for the migration-52 unit test (hack/migration-52-adopt-values.bats).
# Mocks only the cluster boundary. Env:
#   FAKE_HR_LIST  path to the `get helmrelease -o json` list fixture
#   FAKE_CHILD_HR path to write the child HelmRelease that `apply -f -` receives
#   FAKE_CMDLOG   path to append a call log (APPLY-HR / STAMP / annotate / label)
log() { [ -n "${FAKE_CMDLOG:-}" ] && echo "$*" >> "$FAKE_CMDLOG"; return 0; }
verb=${1:-}
shift 2>/dev/null || true
args="$*"
case "$verb" in
  get)
    case "$args" in
      *helmrelease*--all-namespaces*)
        cat "$FAKE_HR_LIST"; exit 0 ;;
      *kubevirtmachinetemplate*)
        exit 0 ;;                       # empty jsonpath list -> KMT loop is a no-op
      *helmrelease*kubernetes-nodes-*)
        exit 1 ;;                       # child HR absent -> script takes the create path
      *)
        exit 1 ;;                       # MD/MHC/WM adopt_one reads -> absent -> skip (no-op-safe)
    esac ;;
  apply)
    payload=$(cat)
    if printf '%s' "$payload" | grep -q 'HelmRelease'; then
      printf '%s' "$payload" > "$FAKE_CHILD_HR"; log "APPLY-HR"
    elif printf '%s' "$payload" | grep -q 'ConfigMap'; then
      log "STAMP"
    else
      log "APPLY-OTHER"
    fi
    exit 0 ;;
  annotate) log "annotate $args"; exit 0 ;;
  label)    log "label $args"; exit 0 ;;
  *) exit 0 ;;
esac
