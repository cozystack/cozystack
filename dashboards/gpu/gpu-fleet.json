{
  "uid": "gpu-fleet",
  "title": "GPU Fleet Overview",
  "description": "Cluster-wide GPU inventory, capacity, utilization and health — admin view across the whole fleet.",
  "tags": [
    "gpu",
    "fleet",
    "admin"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "schemaVersion": 42,
