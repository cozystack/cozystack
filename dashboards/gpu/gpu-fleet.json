        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "id": 2,
      "targets": [
        {
          "expr": "cluster:gpu_count:total",
          "refId": "A"
        }
      ],
      "title": "Total GPUs",
      "description": "Physical GPUs discovered by DCGM across all nodes.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
