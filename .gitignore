tmp/

# build revision marker (generated by make image-packages)
packages/core/platform/.build-revision

# Agent tooling. The md-no-hardwrap hook and its registration are shared with
# every contributor, so they are tracked by name; personal agent state (local
# settings overrides, worktrees, session data) stays out of git. Put personal
# overrides in .claude/settings.local.json -- .claude/settings.json is tracked
# and git will overwrite it on pull.
.claude/*
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/md-no-hardwrap.py
!.claude/settings.json

# Credentials and runtime state minted by the backup/restore demo scripts
# under examples/backups/*/. Files are written by 00-helpers.sh +
# 02-create-bucket.sh + 04-create-backupjob.sh; cleanup.sh deletes them
# on teardown. Keep them out of git so a tenant who runs the demo and
# then `git add .` does not accidentally commit S3 keys.
examples/backups/*/.bucket-info.env
examples/backups/*/.sentinel.env
examples/backups/*/.backup-name.env
packages/core/platform/images/migrations/etcd-operator-crds/

# Personal French-language project summary for the vm-import work. Kept local
# so it does not land in the PR alongside the tracked English docs.
packages/apps/vm-import/docs/PROJECT_SUMMARY.fr.md
