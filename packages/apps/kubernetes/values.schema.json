                  {
                    "type": "string"
                  }
                ],
                "x-kubernetes-int-or-string": true
              }
            }
          },
          "roles": {
            "description": "List of node roles.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "storageClass": {
            "description": "StorageClass for worker node persistent disks. When empty, uses the management cluster default StorageClass (the one annotated storageclass.kubernetes.io/is-default-class: true). NOTE: deliberately not marked immutable — the field is optional and undefaulted, so a strict `self == oldSelf` rule would block any future attempt to set it on an existing node group.",
            "type": "string",
            "x-cozystack-options": {
              "source": "storageclass"
            }
          }
        }
