+    private Flux<ApiCallRc> handleNoopAction(Resource rscRef, boolean removeDiskRef)
+    {
+        String state = removeDiskRef ? "diskless" : "diskful";
+        ApiCallRcImpl responses = new ApiCallRcImpl();
