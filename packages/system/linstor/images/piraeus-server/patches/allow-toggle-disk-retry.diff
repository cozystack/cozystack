+    private Flux<ApiCallRc> handleRetryAction(
+        Resource rscRef,
+        boolean removeDisk,
+        boolean toggleIntoTiebreakerRef,
+        ResponseContext context
+    )
+    {
+        String direction = removeDisk ? "diskless" : "diskful";
