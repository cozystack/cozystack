diff --git a/web/template/login.html.tmpl b/web/template/login.html.tmpl
new file mode 100644
index 0000000..7a1730a
--- /dev/null
+++ b/web/template/login.html.tmpl
@@ -0,0 +1,69 @@
+{{ define "content" }}
+<nav>
+    <div class="nav-wrapper container">
+        <a href="/" class="brand-logo">Cozystack S3 Manager</a>
+    </div>
+</nav>
+
+<div class="container">
+    <div class="section">
+        <div class="row">
+            <div class="col l6 offset-l3 m8 offset-m2 s12">
+                <div class="card">
+                    <div class="card-content">
+                        <span class="card-title">Login</span>
+                        <p>Enter your S3 credentials to access buckets.</p>
+                        <br>
+
+                        {{ if eq .Error "invalid_credentials" }}
+                        <div class="card-panel red lighten-4 red-text text-darken-4">
+                            <i class="material-icons tiny">error</i>
+                            Invalid credentials. Please check your Access Key and Secret Key.
+                        </div>
+                        {{ end }}
+
+                        {{ if eq .Error "credentials_required" }}
+                        <div class="card-panel red lighten-4 red-text text-darken-4">
+                            <i class="material-icons tiny">error</i>
+                            Both Access Key ID and Secret Access Key are required.
+                        </div>
+                        {{ end }}
+
+                        {{ if eq .Error "session_error" }}
+                        <div class="card-panel red lighten-4 red-text text-darken-4">
+                            <i class="material-icons tiny">error</i>
+                            Session error. Please try again.
+                        </div>
+                        {{ end }}
+
+                        <form method="POST" action="/login">
+                            <div class="row">
+                                <div class="input-field col s12">
+                                    <i class="material-icons prefix">vpn_key</i>
+                                    <input id="accessKey" name="accessKey" type="text" required>
+                                    <label for="accessKey">Access Key ID</label>
+                                </div>
+                            </div>
+                            <div class="row">
+                                <div class="input-field col s12">
+                                    <i class="material-icons prefix">lock</i>
+                                    <input id="secretKey" name="secretKey" type="password" required>
+                                    <label for="secretKey">Secret Access Key</label>
+                                </div>
+                            </div>
+                            <div class="row">
+                                <div class="col s12">
+                                    <button type="submit" class="btn waves-effect waves-light" style="width:100%;">
+                                        Sign In
+                                        <i class="material-icons right">send</i>
+                                    </button>
+                                </div>
+                            </div>
+                        </form>
+                    </div>
+                </div>
+            </div>
+        </div>
+    </div>
+</div>
+{{ end }}
