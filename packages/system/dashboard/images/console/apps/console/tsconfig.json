{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "types": ["vite/client", "@testing-library/jest-dom"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@cozystack/types": ["../../packages/types/src"],
      "@cozystack/ui": ["../../packages/ui/src"],
      "@cozystack/ui/*": ["../../packages/ui/src/*"],
      "@cozystack/k8s-client": ["../../packages/k8s-client/src"]
    }
  },
  "include": ["src"]
}
