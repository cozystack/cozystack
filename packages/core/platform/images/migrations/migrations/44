#!/bin/bash
# Migration 44 --> 45
# Pin KubeadmConfigTemplate / KubeadmConfig objects with helm.sh/resource-policy=keep
# so the Talos migration (PR #2610) does not let Helm prune them while CAPI still
# references them from the existing kubeadm-backed MachineSet.
#
# PR #2610 drops KubeadmConfigTemplate from the kubernetes app chart templates
# entirely (workers move to TalosConfigTemplate). On upgrade Helm sees the
# resource present in the previous release manifest but absent in the new one
# and issues a delete. The old MachineSet, which is still around until CAPI
# finishes rolling workers onto Talos, then has its bootstrap.configRef pointing
# at a missing object and floods controller-manager logs with reconcile errors.
# In pathological cases (slow Talos image fetch from factory.talos.dev,
# MachineHealthCheck remediation, etc.) workers can hang in pending state with
# nothing to bootstrap from.
#
# The fix is to annotate every Helm-managed KubeadmConfigTemplate (and the
# KubeadmConfig instances spawned from them) with helm.sh/resource-policy=keep
# *before* the new chart renders. Helm then leaves the object alone, CAPI keeps
# its references intact, and the resources disappear naturally when the old
# MachineSet is finally garbage-collected after the Talos rollover completes.
#
# Idempotent: re-running on already-annotated objects is a no-op
# (kubectl annotate --overwrite tolerates the existing value).
# Best-effort: a failed annotate is logged and leaves the version stamp at 43
# so the migration retries on the next platform upgrade.

set -euo pipefail

DRY_RUN="${MIGRATION_DRY_RUN:-0}"
FAILURES=0
PATCHED=0
SKIPPED=0

KEEP_ANNOTATION="helm.sh/resource-policy=keep"
HELM_RELEASE_LABEL="meta.helm.sh/release-name"

annotate_object() {
  local kind="$1" ns="$2" name="$3"
  local current

  current=$(kubectl get "$kind" --namespace "$ns" "$name" \
    --output 'jsonpath={.metadata.annotations.helm\.sh/resource-policy}' 2>/dev/null || true)

  if [ "$current" = "keep" ]; then
    SKIPPED=$((SKIPPED + 1))
    return 0
  fi

  if [ "$DRY_RUN" = "1" ]; then
    echo "[dry-run] would annotate $kind $ns/$name $KEEP_ANNOTATION"
    PATCHED=$((PATCHED + 1))
    return 0
  fi

  local kubectl_err
  if kubectl_err=$(kubectl annotate "$kind" --namespace "$ns" "$name" \
       "$KEEP_ANNOTATION" --overwrite 2>&1 >/dev/null); then
    echo "Annotated $kind $ns/$name"
    PATCHED=$((PATCHED + 1))
  else
    echo "WARN: failed to annotate $kind $ns/$name: ${kubectl_err:-unknown error}" >&2
    FAILURES=$((FAILURES + 1))
  fi
}

list_helm_managed() {
  local kind="$1" out
  if ! out=$(kubectl get "$kind" --all-namespaces \
       --selector "$HELM_RELEASE_LABEL" \
       --output 'jsonpath={range .items[*]}{.metadata.namespace}{"\t"}{.metadata.name}{"\n"}{end}' \
       2>&1); then
    case "$out" in
      *"the server doesn't have a resource type"*|*"no matches for kind"*|*"NotFound"*) return 0 ;;
    esac
    echo "ERROR: kubectl get $kind failed: $out" >&2
    return 1
  fi
  printf '%s' "$out"
}

for kind in kubeadmconfigtemplates.bootstrap.cluster.x-k8s.io \
            kubeadmconfigs.bootstrap.cluster.x-k8s.io; do
  echo "==> Pinning Helm-managed $kind with $KEEP_ANNOTATION"
  items=$(list_helm_managed "$kind") || exit 1
  while IFS=$'\t' read -r ns name; do
    [ -z "$ns" ] && continue
    annotate_object "$kind" "$ns" "$name"
  done <<<"$items"
done

echo "==> Summary: patched=$PATCHED skipped=$SKIPPED failures=$FAILURES" | tee /dev/stderr

if [ "$DRY_RUN" = "1" ]; then
  echo "Dry-run complete; version stamp not advanced"
  exit 0
fi

if [ "$FAILURES" -gt 0 ]; then
  echo "WARN: $FAILURES annotate(s) failed; leaving CURRENT_VERSION at 43 for retry on next upgrade."
  exit 0
fi

kubectl create configmap --namespace cozy-system cozystack-version \
  --from-literal version=44 --dry-run=client --output yaml \
  | kubectl apply --filename -
