#!/bin/sh
# Migration 54 --> 55
# Phase 2 kubernetes chart split: adopt the worker node pools that the
# monolithic kubernetes chart used to render into per-pool kubernetes-nodes
# HelmReleases.
#
# Before this release, HelmRelease kubernetes-<cluster> rendered the worker
# KubevirtMachineTemplate / MachineDeployment / MachineHealthCheck / worker
# WorkloadMonitor for every entry in spec.values.nodeGroups (plus an implicit
# md0 default when nodeGroups was empty). This release removes those objects
# from the kubernetes chart (they moved to the kubernetes-nodes chart, one
# HelmRelease per pool). On upgrade Helm would see them present in the previous
# kubernetes-<cluster> release manifest but absent in the new one and PRUNE
# them -- destroying the tenant's running worker VMs.
#
# For every parent kubernetes HelmRelease this migration therefore, per pool:
#   1. creates the child HelmRelease kubernetes-nodes-<cluster>-<pool> (which
#      cozystack-api reverse-maps to a KubernetesNodes CR by prefix). The child
#      is created directly as a HelmRelease, not via the aggregated
#      KubernetesNodes API, because that API's ApplicationDefinition only lands
#      later in this same upgrade and would 404 from this pre-upgrade hook.
#   2. re-annotates the existing worker objects onto the child release
#      (meta.helm.sh/release-name) and pins helm.sh/resource-policy=keep so the
#      parent kubernetes-<cluster> upgrade -- which now renders control plane
#      only -- does not prune them during the transition. The child chart then
#      adopts them byte-identically (proven in PR-2a golden parity; the
#      KubevirtMachineTemplate content-hash name is preserved so no worker VM
#      churns).
#
# Runs as a pre-upgrade/pre-install hook, i.e. BEFORE any tenant HelmRelease
# reconciles the new chart, which is the only safe window for the keep +
# re-annotation to land ahead of the parent's control-plane-only re-render.
# That window is not perfectly quiet: if a parent kubernetes-<cluster> HR is
# upgraded during it (a user edit, a forced reconcile, any values change) it
# renders the OLD chart, still emits the pool objects, and Helm rejects the
# apply with an ownership-metadata error. It self-heals once the new chart
# artifact lands, but operators should avoid editing Kubernetes CRs during a
# platform upgrade (also called out in the release notes).
#
# _cluster and nodeHealthCheck are NOT copied into the child values: _cluster is
# injected at runtime from the cozystack-values Secret (referenced via the
# child's valuesFrom, same as every tenant app), and nodeHealthCheck collapses
# into the child's per-pool maxUnhealthy / nodeStartupTimeout below. storageClass
# falls back to the cluster-level value to mirror the parent's
# `group.storageClass | default .Values.storageClass`.
#
# The parent HelmRelease's spec.values keeps its now-unused nodeGroups /
# nodeHealthCheck keys: the new kubernetes chart schema ignores them (no
# additionalProperties:false), and stripping them here would rewrite the parent
# values mid-window and trigger an old-chart re-render. A later cleanup
# migration can drop them once the whole fleet is past version 55.
#
# Idempotent: re-running skips child HRs that already exist and objects already
# adopted. Strict: any failed create/annotate exits 1 so run-migrations.sh
# leaves CURRENT_VERSION at 54 and retries on the next upgrade -- best-effort is
# unsafe because a pool left un-pinned is pruned by the parent upgrade.
#
# NOT auto-reversible: downgrading the platform re-renders the OLD kubernetes
# chart, whose manifest still lists the worker objects now annotated
# meta.helm.sh/release-name=kubernetes-nodes-<cluster>-<pool>; the parent
# upgrade then fails Helm ownership validation. To roll back, first re-annotate
# every adopted object back to the parent release:
#   kubectl annotate <res> <name> -n <ns> \
#     meta.helm.sh/release-name=kubernetes-<cluster> --overwrite
# (and remove the kubernetes-nodes-<cluster>-<pool> HelmReleases) BEFORE
# downgrading the kubernetes chart.

set -euo pipefail

# shellcheck source=lib/cozystack-version.sh
. "$(dirname "$0")/lib/cozystack-version.sh"

CHILD_CHART_REF_NAME="cozystack-kubernetes-nodes-application-kubevirt-kubernetes-nodes"

# The implicit default node group the parent chart's kubernetes.nodeGroups helper
# injected when spec.values.nodeGroups was empty. Materialised explicitly so a
# cluster that relied on the default keeps its (ingress-nginx-roled) md0 pool.
DEFAULT_MD0='{"minReplicas":0,"maxReplicas":10,"instanceType":"u1.medium","diskSize":"20Gi","storageClass":"","roles":["ingress-nginx"],"resources":{},"gpus":[],"kubelet":{}}'

# adopt_one <resource> <object-name> <namespace> <new-release> <expected-old-release>
adopt_one() {
  res=$1; obj=$2; ns=$3; new_rel=$4; old_rel=$5
  if ! kubectl get "$res" "$obj" -n "$ns" >/dev/null 2>&1; then
    echo "    $res/$obj absent in $ns, skipping"
    return 0
  fi
  cur=$(kubectl get "$res" "$obj" -n "$ns" \
    -o jsonpath='{.metadata.annotations.meta\.helm\.sh/release-name}' 2>/dev/null || true)
  if [ "$cur" = "$new_rel" ]; then
    echo "    $res/$obj already adopted by $new_rel"
    return 0
  fi
  if [ -n "$cur" ] && [ "$cur" != "$old_rel" ]; then
    echo "    $res/$obj owned by unexpected release '$cur' (expected '$old_rel'); refusing" >&2
    return 1
  fi
  echo "    adopting $res/$obj -> $new_rel"
  kubectl annotate "$res" "$obj" -n "$ns" \
    helm.sh/resource-policy=keep \
    meta.helm.sh/release-name="$new_rel" \
    --overwrite
  kubectl label "$res" "$obj" -n "$ns" \
    app.kubernetes.io/managed-by=Helm --overwrite
}

# pin_keep <resource> <object-name> <namespace> -- protect an object from the
# parent's control-plane-only re-render prune without transferring ownership.
# Used for pools we cannot adopt (name overflow): the workers keep running,
# unmanaged, until the operator gives the cluster a shorter name.
pin_keep() {
  res=$1; obj=$2; ns=$3
  if kubectl get "$res" "$obj" -n "$ns" >/dev/null 2>&1; then
    echo "    pinning $res/$obj with resource-policy=keep"
    kubectl annotate "$res" "$obj" -n "$ns" helm.sh/resource-policy=keep --overwrite
  fi
}

# pin_pool_objects <cluster> <group> <namespace> -- pin every worker object of a
# pool we cannot adopt (name overflow, or a name that is not a valid HelmRelease
# metadata.name) so the parent's control-plane-only re-render cannot prune them.
# The pool keeps running unmanaged until the operator recreates it with a legal
# name. Existence-checked inside pin_keep, so it is a safe no-op when the objects
# are absent (a pool that never rendered under a bad name).
pin_pool_objects() {
  cluster=$1; group=$2; ns=$3
  pin_keep "machinedeployment.cluster.x-k8s.io" "kubernetes-${cluster}-${group}" "$ns"
  pin_keep "machinehealthcheck.cluster.x-k8s.io" "kubernetes-${cluster}-${group}" "$ns"
  pin_keep "workloadmonitor.cozystack.io" "kubernetes-${cluster}-${group}" "$ns"
  for kmt in $(kubectl get kubevirtmachinetemplate.infrastructure.cluster.x-k8s.io -n "$ns" \
                 -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null |
               grep -E "^kubernetes-${cluster}-${group}-[0-9a-f]{6}$" || true); do
    pin_keep "kubevirtmachinetemplate.infrastructure.cluster.x-k8s.io" "$kmt" "$ns"
  done
}

kubectl get helmrelease --all-namespaces \
  -l apps.cozystack.io/application.kind=Kubernetes -o json |
  jq -c '.items[] | {ns: .metadata.namespace, name: .metadata.name, values: (.spec.values // {})}' |
  while IFS= read -r hrjson; do
    ns=$(printf '%s' "$hrjson" | jq -r '.ns')
    name=$(printf '%s' "$hrjson" | jq -r '.name')
    values=$(printf '%s' "$hrjson" | jq -c '.values')

    case "$name" in
      kubernetes-*) cluster=${name#kubernetes-} ;;
      *) echo "skipping HelmRelease with unexpected name '$name' in $ns" >&2; continue ;;
    esac
    echo "processing cluster '$cluster' (HelmRelease $name in $ns)"

    groups_json=$(printf '%s' "$values" | jq -c '.nodeGroups // {}')
    if [ "$(printf '%s' "$groups_json" | jq 'length')" -eq 0 ]; then
      echo "  nodeGroups empty; materialising implicit md0 default"
      groups_json=$(jq -cn --argjson d "$DEFAULT_MD0" '{md0: $d}')
    fi

    for group in $(printf '%s' "$groups_json" | jq -r 'keys[]'); do
      child_name="kubernetes-nodes-${cluster}-${group}"
      app_name="${cluster}-${group}"
      grp=$(printf '%s' "$groups_json" | jq -c --arg g "$group" '.[$g]')

      # A HelmRelease metadata.name must be a valid RFC-1123 label. The old
      # nodeGroups map key was never schema-constrained (map[string]NodeGroup,
      # no propertyNames pattern), so a stored parent HR can carry a key like
      # "My_Pool" — added via kubectl/dashboard, whose own render then failed at
      # apply time, leaving the HR stuck on an older revision with the bad key
      # persisted. child_name would then be RFC-1123-invalid, `kubectl apply`
      # rejects it, and under set -e the script exits 1 — deadlocking the
      # platform pre-upgrade hook for EVERY tenant, exactly the failure the
      # overflow branch below was built to avoid. Route it through the same
      # warn + pin + skip path (a pool that never rendered under a bad name has
      # no objects, so pin_pool_objects is a safe no-op — the warning is the
      # point).
      if ! printf '%s' "$child_name" | grep -qE '^[a-z0-9]([-a-z0-9]*[a-z0-9])?$'; then
        echo "  WARNING: child release name '$child_name' (nodeGroup key '$group') is not a valid RFC-1123 label" >&2
        echo "  WARNING: pinning pool '$cluster'/'$group' objects with resource-policy=keep and skipping adoption" >&2
        echo "  WARNING: remedy: recreate the pool with an RFC-1123 name (lowercase alphanumeric and '-', must start and end alphanumeric)" >&2
        pin_pool_objects "$cluster" "$group" "$ns"
        continue
      fi

      # Helm refuses release names longer than 53 characters. A legal long
      # cluster name (up to 42 chars per rest.go) plus the longer
      # kubernetes-nodes- prefix can overflow. Do NOT fail the whole migration
      # here: exiting would deadlock the platform pre-upgrade hook for EVERY
      # tenant, with no path out. Instead pin this pool's worker objects with
      # resource-policy=keep so the parent's control-plane-only re-render cannot
      # prune them, skip creating the child HelmRelease, warn loudly, and move
      # on. The pool keeps running unmanaged until the operator recreates the
      # cluster with a shorter name (cluster+pool must fit in 36 chars).
      if [ "${#child_name}" -gt 53 ]; then
        echo "  WARNING: child release name '$child_name' (${#child_name} chars) exceeds Helm's 53-char limit" >&2
        echo "  WARNING: pinning pool '$cluster'/'$group' objects with resource-policy=keep and skipping adoption" >&2
        echo "  WARNING: remedy: recreate the cluster with a shorter name (cluster+pool must fit in 36 chars)" >&2
        pin_pool_objects "$cluster" "$group" "$ns"
        continue
      fi

      child_values=$(printf '%s' "$values" | jq -c \
        --arg cluster "$cluster" \
        --argjson grp "$grp" '
        def pick($o; ks): reduce ks[] as $k ({}; if ($o | has($k)) then . + {($k): $o[$k]} else . end);
        ({cluster: $cluster}
         + pick($grp; ["minReplicas","maxReplicas","instanceType","diskSize","roles","resources","gpus","kubelet"])
         # storageClass: per-group value if set and non-empty, else cluster-level
         # (mirrors the parent `group.storageClass | default .Values.storageClass`).
         + (if (($grp | has("storageClass")) and ($grp.storageClass != "")) then {storageClass: $grp.storageClass}
            elif (has("storageClass") and (.storageClass != null)) then {storageClass: .storageClass}
            else {} end)
         # effective MHC knobs: per-group override, else cluster-wide nodeHealthCheck
         + (if ($grp | has("maxUnhealthy")) then {maxUnhealthy: $grp.maxUnhealthy}
            elif ((.nodeHealthCheck | type) == "object" and (.nodeHealthCheck | has("maxUnhealthy"))) then {maxUnhealthy: .nodeHealthCheck.maxUnhealthy}
            else {} end)
         + (if ($grp | has("nodeStartupTimeout")) then {nodeStartupTimeout: $grp.nodeStartupTimeout}
            elif ((.nodeHealthCheck | type) == "object" and (.nodeHealthCheck | has("nodeStartupTimeout"))) then {nodeStartupTimeout: .nodeHealthCheck.nodeStartupTimeout}
            else {} end)
         # cluster-level inputs the pool templates consume verbatim
         + pick(.; ["version","talos"])
         # images: copy only the declared kubectl override, not the whole
         # parent images map (which carries waitForKubeconfig/talosCsrSigner that
         # the KubernetesNodes schema does not declare and a dashboard round-trip
         # would drop).
         + (if ((.images | type) == "object" and (.images | has("kubectl"))) then {images: {kubectl: .images.kubectl}} else {} end)
        )')

      # Adopt the worker objects the parent rendered for this group BEFORE
      # creating the child HelmRelease. If the kubernetes-nodes ExternalArtifact
      # already exists (Phase 2a shipped in an earlier release), helm-controller
      # can start the child install the moment the HR appears; adopting first
      # guarantees the keep + release-name annotations are already in place, so
      # the child install never trips Helm's ownership validation.
      adopt_one "machinedeployment.cluster.x-k8s.io" "kubernetes-${cluster}-${group}" "$ns" "$child_name" "kubernetes-${cluster}"
      adopt_one "machinehealthcheck.cluster.x-k8s.io" "kubernetes-${cluster}-${group}" "$ns" "$child_name" "kubernetes-${cluster}"
      adopt_one "workloadmonitor.cozystack.io" "kubernetes-${cluster}-${group}" "$ns" "$child_name" "kubernetes-${cluster}"

      # All KubevirtMachineTemplates for this group carry a 6-hex content-hash
      # suffix (parent chart: sha256sum | trunc 6): kubernetes-<cluster>-<group>-<hash>.
      # Anchor on that suffix so pool 'md0' does not also match a sibling pool
      # 'md0-large-<hash>' (which would mis-adopt it and deadlock the migration).
      # Adopt every revision (current + any preserved older one still referenced
      # by an in-flight MachineSet).
      for kmt in $(kubectl get kubevirtmachinetemplate.infrastructure.cluster.x-k8s.io -n "$ns" \
                     -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null |
                   grep -E "^kubernetes-${cluster}-${group}-[0-9a-f]{6}$" || true); do
        adopt_one "kubevirtmachinetemplate.infrastructure.cluster.x-k8s.io" "$kmt" "$ns" "$child_name" "kubernetes-${cluster}"
      done

      if kubectl get helmrelease "$child_name" -n "$ns" >/dev/null 2>&1; then
        echo "  child HelmRelease $child_name already exists, skipping create"
      else
        echo "  creating child HelmRelease $child_name"
        # HR shape mirrors pkg/registry/apps/application/rest.go
        # convertApplicationToHelmRelease (interval, maxHistory, RetryOnFailure
        # strategy + retryInterval, timeouts+disableWait from the kubernetes-nodes
        # ApplicationDefinition annotations) so an adopted pool is byte-shaped
        # like a natively created one and self-heals on a failed install.
        jq -cn \
          --arg name "$child_name" --arg ns "$ns" --arg app "$app_name" \
          --arg chart "$CHILD_CHART_REF_NAME" --argjson values "$child_values" '
          {
            apiVersion: "helm.toolkit.fluxcd.io/v2",
            kind: "HelmRelease",
            metadata: {
              name: $name,
              namespace: $ns,
              labels: {
                "sharding.fluxcd.io/key": "tenants",
                "apps.cozystack.io/application.kind": "KubernetesNodes",
                "apps.cozystack.io/application.group": "apps.cozystack.io",
                "apps.cozystack.io/application.name": $app
              }
            },
            spec: {
              interval: "5m",
              maxHistory: 5,
              chartRef: { kind: "ExternalArtifact", name: $chart, namespace: "cozy-system" },
              install: {
                timeout: "15m",
                disableWait: true,
                strategy: { name: "RetryOnFailure", retryInterval: "30s" }
              },
              upgrade: {
                timeout: "15m",
                disableWait: true,
                strategy: { name: "RetryOnFailure", retryInterval: "30s" }
              },
              valuesFrom: [ { kind: "Secret", name: "cozystack-values" } ],
              values: $values
            }
          }' | kubectl apply --filename -
      fi
    done
  done

# Stamp version via the shared helper so the no-delete label is preserved.
stamp_cozystack_version 55
